# ============================================
# CatRealm Self-Hosted Server Configuration
# ============================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=40500
SERVER_URL=http://0.0.0.0:40500
SERVER_NAME=My CatRealm Server
SERVER_DESCRIPTION=A cozy self-hosted chat server

# ── Security ───────────────────────────────────────────────────────────────────
# This will auto generate
JWT_SECRET=change-this-to-a-long-random-string
# Message-at-rest secure mode (0=disabled, 1=enabled and permanently locked)
# Supports either SECURE_MODE or secure-mode
SECURE_MODE=1
# This is auto generated when SECURE_MODE=1
SECURE_MODE_KEY=
# You can also manually make a random key if you don't want it to auto make one (min 16)

# ── Registration ───────────────────────────────────────────────────────────────
# Set to 'false' to prevent new signups (invite-only)
REGISTRATION_OPEN=true

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=./data/catrealm.db

# ── Multi-Realm (advanced, off by default) ────────────────────────────────────
# Run several independent realms from this one install, each on its own port
# with its own database, sharing LiveKit and the uploads/UGC folders.
# On first boot with MULTI_REALM=true, the current database is safely copied to
# data/<port>.db and data/realms.json is created — edit that file to add more
# realms (per-realm secrets/overrides live in data/realms/<port>.env).
# See docs/MULTI_REALM.md for details.
#MULTI_REALM=false

# ── Bots ───────────────────────────────────────────────────────────────────────
# Token bots are created from Realm Settings → Bots. Plugin bots are folders
# under data/bots/<name>/ (with a bot.json manifest) that the server runs as
# child processes. Set to false to disable the plugin loader entirely.
# See docs/BOTS.md for details.
#BOTS_PLUGINS_ENABLED=true

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set to your client's URL in production, or leave as * for open access
CLIENT_URL=*

# ── Uploads ────────────────────────────────────────────────────────────────────
UPLOADS_DIR=./data/uploads
UGC_IMAGES_DIR=./data/ugc/images

# Optional: default avatar URL for newly created local/central-linked users
#DEFAULT_AVATAR_URL=https://cdn.example.com/default-avatar.png

# Optional: block exact usernames (case-insensitive, applied in decentral_only mode)
#BLOCKED_USERNAMES=admin,moderator,official
#BLOCKED_USERNAMES_FILE=./blocked-usernames.txt

# Server Mode (optional)
# - decentral_only: Only local accounts
# - mixed: Both local and central accounts (default)
# - central_only: Only central accounts
#SERVER_MODE=mixed

# ── Media Limits ───────────────────────────────────────────────────────────────
#MEDIA_MAX_MB=20
# Chat upload compression (images + mp4 only; excludes gifs/apng/emotes/stickers/server assets)
#COMPRESS_MEDIA=0
# 0-9 (higher = stronger compression, more CPU). Only used when COMPRESS_MEDIA=1
#LEVEL_OF_COMPRESSION=6
#AVATAR_MAX_MB=10
#MAX_PINS=300
#MENTION_ALIAS=@everyone

# ── RTC Media Sidecar (LiveKit/SFU) ───────────────────────────────────────────
# Voice and theater media require either local LiveKit or central LiveKit fallback.
# For Pterodactyl bundled mode, set HOST_LIVEKIT_MEDIA=true and use the
# CatRealm runtime image that includes LiveKit.
#HOST_LIVEKIT_MEDIA=false
#LIVEKIT_PUBLIC_HOST=media.example.com
#LIVEKIT_SIGNALING_PORT=7880
#LIVEKIT_RTC_TCP_PORT=7881
#LIVEKIT_RTC_UDP_PORT_START=50000
#LIVEKIT_RTC_UDP_PORT_END=50100
# Optional: enables bundled Redis + LiveKit Ingress so native encoders can publish
# pre-encoded H.264 over WHIP without moving raw frames through Electron.
# Requires the CatRealm runtime image with Ingress and one extra UDP allocation
# for LIVEKIT_INGRESS_RTC_UDP_PORT.
#HOST_LIVEKIT_INGRESS=false
#LIVEKIT_REDIS_PORT=6379
#LIVEKIT_REDIS_ADDRESS=
#LIVEKIT_INGRESS_WHIP_PORT=8080
#LIVEKIT_INGRESS_RTC_UDP_PORT=7885
# Experimental: transcode native WHIP screen shares into simulcast layers for lower-bitrate viewers.
#CATREALM_EXPERIMENTAL_WHIP_SIMULCAST=false
#MEDIA_LIVEKIT_INGRESS_ENABLED=false
#MEDIA_LIVEKIT_WHIP_PUBLIC_URL=https://media.example.com/whip
#MEDIA_LIVEKIT_ENABLED=false
#MEDIA_LIVEKIT_URL=http://127.0.0.1:7880
#MEDIA_LIVEKIT_PUBLIC_WS_URL=wss://media.example.com
#MEDIA_LIVEKIT_API_KEY=devkey
#MEDIA_LIVEKIT_API_SECRET=devsecret
#MEDIA_TOKEN_TTL_SECONDS=600
# Optional: when local LiveKit is unavailable, mint voice/theater tokens from CatRealm central LiveKit.
# Requires PUSH_RELAY_SECRET registration and a public SERVER_URL/PUBLIC_URL.
#CENTRAL_LIVEKIT_FALLBACK=false
# Optional stable namespace for voice:{serverId}:{channelId} and theater:{serverId}:{channelId}
#CATREALM_SERVER_ID=

# ── SSL / Auto-SSL ────────────────────────────────────────────────────────────
# Auto-SSL via Let's Encrypt (set both to enable)
#SSL_DOMAIN=example.com
#SSL_EMAIL=admin@example.com

# Challenge mode — leave blank for HTTP-01 (requires port 80)
# Set both for DNS-01 (no port 80 needed). Supported providers: cloudflare
#SSL_DNS_PROVIDER=cloudflare
#SSL_DNS_API_TOKEN=your-cloudflare-api-token

# Or provide manual certificate paths
#SSL_CERT_PATH=/path/to/fullchain.pem
#SSL_KEY_PATH=/path/to/privkey.pem

# ── Pterodactyl Support ───────────────────────────────────────────────────────
# These are auto-detected by Pterodactyl, no need to set manually
#SERVER_PORT=25600

# ── Auto Update (Git) ─────────────────────────────────────────────────────────
# If true, startup launcher will fetch/reset to origin/GIT_BRANCH when .git exists.
AUTO_UPDATE=true
GIT_REPO=https://github.com/VanillaChan6571/CatRealm-SelfHostable-Server.git
GIT_BRANCH=main

# ── Push Notification Relay (optional) ────────────────────────────────────────
# Enables @mention push notifications for central account users on this server.
# Generate your own secret — this server self-registers with the central server
# automatically on startup. No coordination with CatRealm required.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#PUSH_RELAY_SECRET=
#AUTH_SERVER_URL=https://auth.catrealm.app
